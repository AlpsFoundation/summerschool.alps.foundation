---
const values = [
  'Openness',
  'Loving-Kindness',
  'Honesty',
  'Responsibility',
  'Rationality',
];

const overview = [
  { label: 'Date', value: '26 July – 01 August 2026' },
  { label: 'Location', value: 'Fondation Le Camp, Vaumarcus, Switzerland' },
  { label: 'Applications', value: '30 March – 30 April 2026' },
  { label: 'Language', value: 'English' },
  { label: 'Participants', value: '25 – 30' },
];

const included = [
  'All-inclusive stay at Le Camp (26 July – 01 August)',
  'Accommodation, breakfast, lunch, dinner and coffee breaks',
  'Expert-led lectures and discussions',
  'Hands-on practical workshops',
  'Engaging social program',
  'Small cohort of 25–30 participants',
  'Certificate of participation',
  'ECTS depending on your institution’s policy',
  'TBD: postgraduate credits (FSP/FMH)',
];

const notIncluded = ['Personal insurance', 'Transportation to Vaumarcus'];
---

<section id="info" class="py-[clamp(4rem,8vw,7rem)]">
  <div class="container-x">
    <div class="mb-[clamp(2rem,4vw,3rem)] flex max-w-[820px] flex-col gap-4">
      <span class="eyebrow self-start">General information</span>
      <h2>Philosophy, offering &amp; everything you need to know.</h2>
      <p>
        The ALPS Foundation is guided by five core values that fuel the Summer
        School&rsquo;s aim to support both academic and personal growth.
      </p>
    </div>

    <ul
      class="gradient-border mb-[clamp(2.5rem,4vw,3.5rem)] grid list-none grid-cols-2 gap-px p-0 md:grid-cols-5"
    >
      {
        values.map((v, i) => (
          <li
            class="flex min-h-[100px] flex-col gap-[0.35rem] bg-[#08030c] px-[1.2rem] py-[1.1rem]"
          >
            <span
              class="text-[0.72rem] font-semibold tracking-[0.14em] text-[var(--color-primary)]"
              style="color: var(--color-primary);"
            >
              0{i + 1}
            </span>
            <span class="text-[1.05rem] font-medium tracking-[-0.01em] text-white">
              {v}
            </span>
          </li>
        ))
      }
    </ul>

    <div class="grid grid-cols-1 gap-4 lg:grid-cols-[1fr_1.2fr]">
      <div class="card">
        <h3 class="mb-5 text-[1.1rem] font-medium">Event overview</h3>
        <dl class="m-0 grid gap-[0.9rem]">
          {
            overview.map((o, idx) => (
              <div
                class:list={[
                  'grid grid-cols-[120px_1fr] items-baseline gap-4 pb-[0.9rem]',
                  idx < overview.length - 1 && 'border-b border-dashed border-[var(--color-border)]',
                ]}
              >
                <dt
                  class="text-[0.78rem] uppercase tracking-[0.12em] text-[var(--color-fg-subtle)]"
                >
                  {o.label}
                </dt>
                <dd class="m-0 text-white">{o.value}</dd>
              </div>
            ))
          }
        </dl>
      </div>

      <div class="card">
        <h3 class="mb-5 text-[1.1rem] font-medium">What&rsquo;s included</h3>
        <ul class="m-0 grid list-none gap-[0.55rem] p-0">
          {
            included.map((i) => (
              <li class="relative pl-[1.6rem] leading-[1.45] text-white/90">
                <span
                  aria-hidden="true"
                  class="grad-primary absolute left-0 top-[0.45em] h-[14px] w-[14px] rounded-full shadow-[0_0_12px_rgba(154,0,109,0.55)]"
                />
                {i}
              </li>
            ))
          }
        </ul>

        <h4
          class="mb-3 mt-7 text-[0.78rem] font-medium uppercase tracking-[0.14em] text-[var(--color-fg-subtle)]"
        >
          Not included
        </h4>
        <ul class="m-0 grid list-none gap-[0.55rem] p-0">
          {
            notIncluded.map((i) => (
              <li class="relative pl-[1.6rem] leading-[1.45] text-white/90">
                <span
                  aria-hidden="true"
                  class="absolute left-[0.15em] top-[0.9em] h-[2px] w-[10px] rounded-[2px] bg-[var(--color-fg-subtle)]"
                />
                {i}
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div
      class="card mt-[clamp(2rem,4vw,3rem)] flex flex-col items-start justify-between gap-5 md:flex-row md:items-center"
      style="background: linear-gradient(135deg, rgba(154,0,109,0.25), rgba(255,255,255,0.02) 60%);"
    >
      <div>
        <h3 class="mb-2 font-medium">Contribute to the week</h3>
        <p class="m-0 max-w-[560px]">
          Bring your favourite musical instrument or a research poster — we
          love when participants shape the program. Mention it at the end of
          the application form.
        </p>
      </div>
      <a
        href="https://docs.google.com/forms/d/e/1FAIpQLScbruwrTJoezVXMo9Wf-L62wcfEnWKX8PllpCaui1l3TiWEMw/viewform"
        target="_blank"
        rel="noopener noreferrer"
        class="btn"
      >
        Apply now
      </a>
    </div>
  </div>
</section>
