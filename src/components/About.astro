---
const cards = [
  {
    title: 'Expert-led lectures',
    body: 'Renowned psychedelic researchers deliver daily talks and guide group discussions on current science.',
    image: '/assets/lecture.jpg',
    alt: 'A lecture at the ALPS Summer School',
  },
  {
    title: 'Hands-on workshops',
    body: 'Experienced facilitators lead interactive workshops blending theory with practical skills and reflection.',
    image: '/assets/location-mood.jpg',
    alt: 'Evening mood and setting at the summer school venue',
  },
  {
    title: 'Community & nature',
    body: 'Evenings and breaks unfold in forest, by the fire and overlooking Lake Neuchâtel — in a small cohort of 25–30.',
    image: '/assets/group-circle.jpg',
    alt: 'ALPS participants gathered in a circle outdoors',
  },
];

// One word per manifesto chapter, in manifesto order, linking to its anchor.
const values = [
  { word: 'Groundedness', anchor: 'grounded-purpose' },
  { word: 'Safety', anchor: 'psychological-safety' },
  { word: 'Care', anchor: 'participant-experience' },
  { word: 'Kindness', anchor: 'fun-and-kindness' },
  { word: 'Commitment', anchor: 'collective-commitment' },
];

const overview = [
  { label: 'Date', value: '26 July – 01 August 2026' },
  { label: 'Location', value: 'Fondation Le Camp, Vaumarcus, Switzerland' },
  { label: 'Applications', value: 'Closed' },
  { label: 'Language', value: 'English' },
  { label: 'Participants', value: '25 – 30' },
];

const included = [
  'All-inclusive stay at Le Camp (26 July – 01 August)',
  'Accommodation, breakfast, lunch, dinner and coffee breaks',
  'Expert-led lectures and discussions',
  'Hands-on practical workshops',
  'Engaging social program',
  'Small cohort of 25–30 participants',
  'Certificate of participation',
  'ECTS depending on your institution’s policy',
];

const notIncluded = ['Personal insurance', 'Transportation to Vaumarcus'];
---

<section
  id="about"
  class="py-[clamp(4rem,8vw,7rem)]"
>
  <div class="container-x">
    <div class="mb-[clamp(2.5rem,5vw,4rem)] flex max-w-[820px] flex-col gap-4">
      <span class="eyebrow self-start">What is the Summer School?</span>
      <h2>
        An immersive week of{' '}
        <span class="grad-text">psychedelic science</span>, therapy
        and personal growth.
      </h2>
      <p>
        The ALPS Summer School is an educational program focused
        on <strong>psychedelic science</strong> — offering a holistic
        opportunity for both <strong>professional and personal development</strong>.
      </p>
      <p>
        Renowned researchers deliver lectures and lead discussions;
        experienced facilitators guide <strong>interactive workshops</strong>; engaging
        social events complement the experience — all in close proximity to
        nature. A well-balanced schedule offers a <strong>comprehensive overview of
        current research</strong> and space to explore intersections between fields.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
      {
        cards.map((c) => (
          <article class="card flex flex-col overflow-hidden !p-0">
            <img
              src={c.image}
              alt={c.alt}
              loading="lazy"
              class="aspect-[4/3] w-full shrink-0 object-cover"
            />
            <div class="flex flex-col gap-3 p-[clamp(1.25rem,2.5vw,2rem)]">
              <h3>{c.title}</h3>
              <p>{c.body}</p>
            </div>
          </article>
        ))
      }
    </div>

    <div id="info" class="mt-[clamp(3.5rem,6vw,5.5rem)]">
      <div class="mb-[clamp(2rem,4vw,3rem)] flex max-w-[820px] flex-col gap-4">
        <span class="eyebrow self-start">Philosophy &amp; practical details</span>
        <h2>Our values, the offering &amp; everything you need to know.</h2>
        <p>
          The Summer School is guided by the values written down in our
          <a
            href="/#manifesto"
            class="text-white underline decoration-[var(--color-accent)] decoration-2 underline-offset-4 hover:text-[var(--color-accent)]"
          >manifesto</a> — the standard we hold ourselves to. Each word below
          opens the chapter it summarizes.
        </p>
      </div>

      <ul
        class="gradient-border mb-[clamp(2.5rem,4vw,3.5rem)] grid list-none grid-cols-1 gap-px p-0 md:grid-cols-5"
      >
        {
          values.map((v, i) => (
            <li class="contents">
              <a
                href={`/#${v.anchor}`}
                class="group flex min-h-[100px] flex-col gap-[0.35rem] bg-[#08030c] px-[1.2rem] py-[1.1rem] transition-colors hover:bg-[rgba(154,0,109,0.12)]"
              >
                <span
                  class="text-[0.72rem] font-semibold tracking-[0.14em]"
                  style="color: var(--color-primary);"
                >
                  0{i + 1}
                </span>
                <span class="text-[1.05rem] font-medium tracking-[-0.01em] text-white group-hover:text-white">
                  {v.word}
                </span>
                <span
                  class="mt-auto text-[0.72rem] text-[var(--color-fg-subtle)] opacity-0 transition-opacity group-hover:opacity-100"
                >
                  Read the chapter →
                </span>
              </a>
            </li>
          ))
        }
      </ul>

      <div class="grid grid-cols-1 gap-4 lg:grid-cols-[1fr_1.2fr]">
        <div class="card">
          <h3 class="mb-5 text-[1.1rem] font-medium">Event overview</h3>
          <dl class="m-0 grid gap-[0.9rem]">
            {
              overview.map((o, idx) => (
                <div
                  class:list={[
                    'grid grid-cols-[120px_1fr] items-baseline gap-4 pb-[0.9rem]',
                    idx < overview.length - 1 && 'border-b border-dashed border-[var(--color-border)]',
                  ]}
                >
                  <dt
                    class="text-[0.78rem] uppercase tracking-[0.12em] text-[var(--color-fg-subtle)]"
                  >
                    {o.label}
                  </dt>
                  <dd class="m-0 text-white">{o.value}</dd>
                </div>
              ))
            }
          </dl>
        </div>

        <div class="card">
          <h3 class="mb-5 text-[1.1rem] font-medium">What&rsquo;s included</h3>
          <ul class="m-0 grid list-none gap-[0.55rem] p-0">
            {
              included.map((i) => (
                <li class="relative pl-[1.6rem] leading-[1.45] text-white/90">
                  <span
                    aria-hidden="true"
                    class="grad-primary absolute left-0 top-[0.45em] h-[14px] w-[14px] rounded-full shadow-[0_0_12px_rgba(154,0,109,0.55)]"
                  />
                  {i}
                </li>
              ))
            }
          </ul>

          <h4
            class="mb-3 mt-7 text-[0.78rem] font-medium uppercase tracking-[0.14em] text-[var(--color-fg-subtle)]"
          >
            Not included
          </h4>
          <ul class="m-0 grid list-none gap-[0.55rem] p-0">
            {
              notIncluded.map((i) => (
                <li class="relative pl-[1.6rem] leading-[1.45] text-white/90">
                  <span
                    aria-hidden="true"
                    class="absolute left-[0.15em] top-[0.9em] h-[2px] w-[10px] rounded-[2px] bg-[var(--color-fg-subtle)]"
                  />
                  {i}
                </li>
              ))
            }
          </ul>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  #about strong {
    font-weight: 500;
    color: rgba(255, 255, 255, 0.95);
  }
</style>
