---
const days = [
  { num: 1, date: 'Sunday 26 July', theme: 'Arrivals, welcome & introduction', tag: 'Day 1' },
  { num: 2, date: 'Monday 27 July', theme: 'Foundations', tag: 'Day 2' },
  { num: 3, date: 'Tuesday 28 July', theme: 'Clinical frontiers', tag: 'Day 3' },
  { num: 4, date: 'Wednesday 29 July', theme: 'Psychedelics in the brain', tag: 'Day 4' },
  { num: 5, date: 'Thursday 30 July', theme: 'Cutting edge applications and research', tag: 'Day 5' },
  { num: 6, date: 'Friday 31 July', theme: 'Society, ethics & integration', tag: 'Day 6' },
];

type Speaker = {
  name: string;
  title?: string;
  affiliations?: string[];
  scholar?: string;
  image: string;
  bio: string[];
};

const speakers: Speaker[] = [
  {
    name: 'Helena Aicher',
    title: 'PhD',
    affiliations: ['University of Zurich', 'University of Basel'],
    scholar: 'https://scholar.google.com/citations?user=ElX6dX8AAAAJ',
    image: '/assets/speakers-helena-aicher.jpg',
    bio: [
      `Helena is a research associate at the Universities of Zurich and Basel, where she is involved in clinical trials investigating psychedelics. Alongside her research role, she works as a psychotherapist with psychedelic-assisted therapy within Switzerland's framework for limited medical use, primarily in group settings.`,
      `Bridging scientific research and frontline practice, she contributes to the development and safe implementation of psychedelic-assisted therapies. Helena is also active as a trainer in therapist training programs and serves as an advisor to several institutions.`,
    ],
  },
  {
    name: 'Christopher Böhlke',
    title: 'Prof. Dr.',
    affiliations: ['University Hospital Basel'],
    scholar: 'https://scholar.google.com/citations?user=lwNCdt8AAAAJ',
    image: '/assets/speakers-christopher-boehlke.jpg',
    bio: [
      `Christopher is an internist, nephrologist, psychotherapist, and palliative care physician, dedicated to both practicing and researching at the Palliative Care Center and University Hospital Basel. His passion for Psychedelic-Assisted Therapy (PAT) stems from the wish to helping individuals with incurable diseases find acceptance and alleviate their suffering.`,
      `He completed his PAT training at the California Institute of Integral Studies and is a certified MAPS therapist. Recently, Christopher collaborated with a team of international researchers to conduct a Cochrane systematic review of PAT trials in palliative care. He has also initiated a PAT program at the Palliative Care Center in Basel.`,
    ],
  },
  {
    name: 'Jason Day',
    title: 'PhD',
    affiliations: ['University of Fribourg'],
    scholar: 'https://scholar.google.com/citations?user=olWYWbIAAAAJ',
    image: '/assets/speakers-jason-day.jpg',
    bio: [
      `Dr. Jason K. Day is a postdoctoral researcher at the University of Fribourg who specialises in the phenomenology of psychedelic experiences, phenomenological scholarship, and philosophy of attention. They received their PhD in philosophy, summa cum laude, from the University of Fribourg for their phenomenological qualitative study of psychedelic experiences and are currently conducting research on challenging memories in relation to psychedelic-assisted therapy at the Molecular Psychiatry Lab.`,
      `Their most recent publication concerns socio-political issues surrounding the recreational use of psychedelics, with a forthcoming paper on ego-dissolution and book on the phenomenology of psychedelic experiences to follow.`,
      `Their other research interests include anarchist thought and Buddhist philosophy. They are a committee member of the Psychedelic Research Organisation of Fribourg (PROOF) and the Swiss Psychedelic Student Network (SPSN).`,
    ],
  },
  {
    name: 'Klemens Egger',
    title: 'PhD',
    affiliations: ['University Hospital of Psychiatry Zurich'],
    scholar: 'https://scholar.google.com/citations?user=do8wor0AAAAJ',
    image: '/assets/speakers-klemens-egger.jpg',
    bio: [
      `Klemens Egger is a neuroscientist and postdoctoral researcher at the University Hospital of Psychiatry Zurich. He holds a background in chemistry and biomedical neuroscience and completed his PhD on the pharmacology and neurobiology of N,N-dimethyltryptamine (DMT) and harmine.`,
      `His research combines pharmacology with multimodal neuroimaging, including fMRI and PET, to investigate how psychedelic compounds affect brain function and behavior. His current work focuses on the neural mechanisms underlying socio-affective processes such as empathy and compassion, as well as on neurometabolic modeling approaches to better characterize psychedelic-induced changes in brain dynamics.`,
    ],
  },
  {
    name: 'Martha Havenith',
    title: 'PhD',
    affiliations: ['Ernst Strüngmann Institute', 'Max Planck Society'],
    scholar: 'https://scholar.google.com/citations?user=EY_4zioAAAAJ',
    image: '/assets/speakers-martha-havenith.jpg',
    bio: [
      `Martha is a Max Planck research group leader at the Ernst-Strungmann Institute for Neuroscience in Frankfurt, Germany, where she uses virtual reality to study how neurons juggle coexisting cognitive processes during natural behaviour. Her previous career milestones include an M.Sc. in Neuroscience at Oxford University, a Ph.D. at the Max Planck Institute for Brain Research, and postdoctoral research fellowships at University College London and the Donders Institute for Brain, Cognition and Behaviour in Nijmegen, Netherlands.`,
      `Martha is also a certified breathwork facilitator with a decade of experience. Apart from breathwork sessions in individual and group settings, she leads facilitator trainings and workshops for healthcare professionals. In recent years, Martha has been leading pioneering research on the neuronal and clinical effects of breathwork, including a first-of-its-kind study on breathwork and trauma processing. Together with Abdel Nemri, she has also co-authored The Breathwork Handbook: an exploration of the history, neuroscience, psychology, and most importantly the principled practice of breathwork. With this work, Martha's passion is to bridge science and lived experience in exploring the power of breathing.`,
    ],
  },
  {
    name: 'Morten Lietz',
    title: 'PhD candidate',
    affiliations: ['University of Fribourg'],
    scholar: 'https://scholar.google.com/citations?user=O-lRCnMAAAAJ',
    image: '/assets/speakers-morten-lietz.jpg',
    bio: [
      `Morten Lietz is pursuing a Ph.D. in Medical Science, studying LSD's effects on neuroplasticity across the lifespan in a large clinical trial. His work combines neurophysiological, cognitive, subjective, and safety-related measures to examine psychedelic effects in healthy aging.`,
      `He previously helped establish a research program at the University of Groningen in the Netherlands under Prof. Enriquez-Geppert, exploring neuroplasticity-enhancing agents and neuromodulation to improve cognition. He also co-organized the first two Summer Schools on Psychedelic Research in Groningen with Dr. Joost Breeksema and the OPEN Foundation.`,
      `In Switzerland, he served as Educational Program Coordinator for the ALPS Foundation, organizing conferences and summer schools, and now supports the ALPS PsyCare initiative focused on harm reduction and psychological support.`,
      `His research interests include psychedelics' effects on memory, genetics and epigenetics, cognition, and safety.`,
    ],
  },
  {
    name: 'Daniel Meling',
    title: 'PhD',
    affiliations: ['University of Zurich', 'University of Freiburg'],
    scholar: 'https://scholar.google.com/citations?user=qC2w-eMAAAAJ',
    image: '/assets/speakers-daniel-meling.jpg',
    bio: [
      `Daniel Meling has a PhD in Human Sciences, an MSc in Cognitive Science, and a BA in Educational Science and Education Management. In his previous work, he has focused on applying enactive cognitive science to meditation, non-dual awareness, and psychedelic experiences.`,
      `In his empirical research, he conducted more than a hundred phenomenological interviews around psychedelic experiences, including the study of interaction effects between DMT-harmine and meditative practices in experienced meditators during an RCT conducted at a meditation group retreat.`,
    ],
  },
  {
    name: 'Daniel Villiger',
    title: 'PhD',
    affiliations: ['University of Zurich'],
    scholar: 'https://scholar.google.com/citations?user=1ic60aMAAAAJ',
    image: '/assets/speakers-daniel-villiger.jpg',
    bio: [
      `Daniel Villiger, PhD, is a philosopher with an interdisciplinary background and main interests in decision theory, cognitive science, and bioethics. He holds a PhD in Philosophy from the University of Zurich, a PhD in Behavioral Economics from the University of St. Gallen, and an MSc in Psychology from the University of Zurich.`,
      `From 2024 to 2025, he conducted the project Psychedelic Ethics at the Uehiro Oxford Institute at the University of Oxford. He is currently a postdoctoral researcher at the University of Zurich. His work has been published in the American Journal of Bioethics, Synthese, Journal of Ethics, Philosophical Psychology, Journal of Medical Ethics, and other journals.`,
    ],
  },
];
---

<section id="program" class="py-[clamp(4rem,8vw,7rem)]">
  <div class="container-x">
    <div class="mb-[clamp(2rem,4vw,3rem)] flex max-w-[820px] flex-col gap-4">
      <span class="eyebrow self-start">Program</span>
      <h2>Six days, six themes — one cohesive journey.</h2>
      <p>
        Each of the five full days of the ALPS Summer School 2026 focuses on
        a different aspect of psychedelic research, featuring three
        theoretical talks, a practical workshop and a social event every day.
        A comprehensive overview of all lectures and workshops is coming soon.
        Confirmed speakers and their bios are shown below and continually
        updated. Stay tuned for more.
      </p>
    </div>

    <ol class="m-0 grid list-none grid-cols-1 gap-4 p-0 sm:grid-cols-2 lg:grid-cols-3">
      {
        days.map((d) => (
          <li class="card group relative flex min-h-[220px] flex-col gap-4 overflow-hidden">
            <div
              aria-hidden="true"
              class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-200 group-hover:opacity-100"
              style="background: radial-gradient(400px 200px at 110% -20%, rgba(154,0,109,0.18), transparent 60%);"
            />
            <div
              class="grad-text text-[2.75rem] font-medium leading-none tracking-[-0.04em]"
              aria-hidden="true"
            >
              <span>{String(d.num).padStart(2, '0')}</span>
            </div>
            <div class="flex flex-wrap items-center gap-[0.6rem]">
              <span
                class="inline-flex items-center rounded-full border border-[var(--color-border-strong)] px-[0.55rem] py-[0.2rem] text-[0.68rem] uppercase tracking-[0.14em] text-[var(--color-fg-muted)]"
              >
                {d.tag}
              </span>
              <span class="text-[0.82rem] tracking-[0.02em] text-[var(--color-fg-subtle)]">
                {d.date}
              </span>
            </div>
            <h3 class="m-0 text-[1.1rem] font-medium leading-[1.3] text-white">
              {d.theme}
            </h3>
          </li>
        ))
      }
    </ol>

    <div
      class="mt-8 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-gradient-to-r from-[rgba(154,0,109,0.1)] to-[rgba(255,255,255,0.02)] px-6 py-5 text-[0.95rem] text-[var(--color-fg-muted)]"
    >
      Full program details — lectures, workshops and learning objectives —
      publishing soon. Sign up via the application form to be notified.
    </div>

    <div id="speakers" class="mt-[clamp(3.5rem,7vw,6rem)]">
      <div
        class="mb-6 flex flex-col gap-3 border-b border-[var(--color-border)] pb-4 sm:flex-row sm:items-end sm:justify-between"
      >
        <div class="flex max-w-[760px] flex-col gap-3">
          <span class="eyebrow self-start">Speakers</span>
          <h3 class="m-0 text-[clamp(1.6rem,3vw,2.2rem)]">
            Confirmed speakers and facilitators
          </h3>
        </div>
      </div>

      <div class="flex flex-col gap-5">
        {
          speakers.map((speaker) => (
            <article class="card w-full overflow-hidden !p-0">
              <div class="grid gap-0 md:grid-cols-[minmax(220px,28%)_1fr]">
                <img
                  src={speaker.image}
                  alt={speaker.name}
                  class="aspect-[4/5] h-full w-full object-cover"
                  loading="lazy"
                />
                <div class="flex flex-col gap-4 p-5 sm:p-6">
                  <div class="flex flex-col gap-2.5 md:flex-row md:items-center md:justify-between md:gap-4">
                    <div class="flex flex-wrap items-baseline gap-x-2.5 gap-y-1">
                      <h4 class="m-0 text-[1.25rem] font-medium text-white">
                        {speaker.name}
                      </h4>
                      {speaker.title && (
                        <span class="text-[0.95rem] text-[var(--color-fg-subtle)]">
                          {speaker.title}
                        </span>
                      )}
                      {speaker.scholar && (
                        <a
                          href={speaker.scholar}
                          target="_blank"
                          rel="noopener noreferrer"
                          aria-label={`${speaker.name} on Google Scholar`}
                          title="Google Scholar"
                          class="inline-flex translate-y-[2px] items-center text-[var(--color-fg-subtle)] transition-colors hover:text-[var(--color-accent)]"
                        >
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="h-[1rem] w-[1rem]"
                            aria-hidden="true"
                          >
                            <path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z" />
                          </svg>
                        </a>
                      )}
                    </div>
                    {speaker.affiliations && speaker.affiliations.length > 0 && (
                      <div class="flex flex-wrap gap-2 md:flex-shrink-0 md:justify-end">
                        {speaker.affiliations.map((aff) => (
                          <span class="inline-flex items-center rounded-full border border-[var(--color-border-strong)] px-[0.55rem] py-[0.2rem] text-[0.68rem] uppercase tracking-[0.14em] text-[var(--color-fg-muted)]">
                            {aff}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                  <div class="flex flex-col gap-3">
                    {speaker.bio.map((paragraph) => (
                      <p class="m-0 text-[0.92rem] leading-[1.65] text-[var(--color-fg-muted)]">
                        {paragraph}
                      </p>
                    ))}
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
