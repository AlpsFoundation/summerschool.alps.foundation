type Speaker = {
  id: string;
  name: string;
  title?: string;
  affiliations?: string[];
  scholar?: string;
  image: string;
  bio: string[];
};

const speakers: Speaker[] = [
  {
    id: 'speaker-helena-aicher',
    name: 'Helena Aicher',
    title: 'PhD',
    affiliations: ['University of Zurich', 'University of Basel'],
    scholar: 'https://scholar.google.com/citations?user=ElX6dX8AAAAJ',
    image: '/assets/speakers-helena-aicher.jpg',
    bio: [
      `Helena is a research associate at the <strong>Universities of Zurich and Basel</strong>, where she is involved in <mark>clinical trials investigating psychedelics</mark>. Alongside her research role, she works as a psychotherapist with <mark>psychedelic-assisted therapy</mark> within Switzerland's framework for limited medical use, primarily in group settings.`,
      `Bridging scientific research and frontline practice, she contributes to the development and safe implementation of psychedelic-assisted therapies. Helena is also active as a <mark>trainer in therapist training programs</mark> and serves as an advisor to several institutions.`,
    ],
  },
  {
    id: 'speaker-christopher-boehlke',
    name: 'Christopher Böhlke',
    title: 'Prof. Dr.',
    affiliations: ['University Hospital Basel'],
    scholar: 'https://scholar.google.com/citations?user=lwNCdt8AAAAJ',
    image: '/assets/speakers-christopher-boehlke.jpg',
    bio: [
      `Christopher is an internist, nephrologist, psychotherapist, and <mark>palliative care physician</mark>, dedicated to both practicing and researching at the <strong>Palliative Care Center</strong> and <strong>University Hospital Basel</strong>. His passion for <mark>Psychedelic-Assisted Therapy (PAT)</mark> stems from the wish to <mark>helping individuals with incurable diseases find acceptance</mark> and alleviate their suffering.`,
      `He completed his PAT training at the <strong>California Institute of Integral Studies</strong> and is a <mark>certified MAPS therapist</mark>. Recently, Christopher collaborated with a team of international researchers to conduct a <mark>Cochrane systematic review of PAT trials in palliative care</mark>. He has also initiated a PAT program at the <strong>Palliative Care Center in Basel</strong>.`,
    ],
  },
  {
    id: 'speaker-jason-day',
    name: 'Jason Day',
    title: 'PhD',
    affiliations: ['University of Fribourg'],
    scholar: 'https://scholar.google.com/citations?user=olWYWbIAAAAJ',
    image: '/assets/speakers-jason-day.jpg',
    bio: [
      `Dr. Jason K. Day is a postdoctoral researcher at the <strong>University of Fribourg</strong> who specialises in the <mark>phenomenology of psychedelic experiences</mark>, phenomenological scholarship, and <mark>philosophy of attention</mark>. They received their PhD in philosophy, summa cum laude, from the <strong>University of Fribourg</strong> for their phenomenological qualitative study of psychedelic experiences and are currently conducting research on <mark>challenging memories in relation to psychedelic-assisted therapy</mark> at the <strong>Molecular Psychiatry Lab</strong>.`,
      `Their most recent publication concerns socio-political issues surrounding the recreational use of psychedelics, with a forthcoming paper on <mark>ego-dissolution</mark> and book on the phenomenology of psychedelic experiences to follow.`,
      `Their other research interests include <mark>anarchist thought and Buddhist philosophy</mark>. They are a committee member of the <strong>Psychedelic Research Organisation of Fribourg (PROOF)</strong> and the <strong>Swiss Psychedelic Student Network (SPSN)</strong>.`,
    ],
  },
  {
    id: 'speaker-dario-dornbierer',
    name: 'Dario Dornbierer',
    title: 'Dr.',
    affiliations: ['University of Zurich', 'Reconnect Labs'],
    image: '/assets/speakers-dario-dornbierer.jpg',
    bio: [
      `Dario Dornbierer is a pharmaceutical scientist, pharmacist, and neuroscientist (<strong>Dr. sc. ETH Zurich</strong>) and a start-up entrepreneur based in Zurich. During his PhD at the <strong>Psychiatric University Hospital Zurich</strong> he investigated the therapeutic potential of <mark>GHB ("liquid ecstasy") for mood disorders</mark>. Awarded the UZH Entrepreneur Fellowship and an SNF Bridge grant, he went on to develop <mark>synthetic ayahuasca analogues</mark> for psychiatric disorders.`,
      `He co-founded <strong>Reconnect Labs</strong>, a University of Zurich spin-off creating safe, patient-oriented psychedelic treatments, as well as <strong>Galventa</strong>, a sleep-health nutraceuticals start-up. He is a passionate inventor focused on reformulating psychotropic drugs to improve their safety and efficacy.`,
    ],
  },
  {
    id: 'speaker-klemens-egger',
    name: 'Klemens Egger',
    title: 'PhD',
    affiliations: ['University Hospital of Psychiatry Zurich'],
    scholar: 'https://scholar.google.com/citations?user=do8wor0AAAAJ',
    image: '/assets/speakers-klemens-egger.jpg',
    bio: [
      `Klemens Egger is a neuroscientist and postdoctoral researcher at the <strong>University Hospital of Psychiatry Zurich</strong>. He holds a background in chemistry and biomedical neuroscience and completed his PhD on the <mark>pharmacology and neurobiology of N,N-dimethyltryptamine (DMT) and harmine</mark>.`,
      `His research combines pharmacology with <mark>multimodal neuroimaging, including fMRI and PET</mark>, to investigate how psychedelic compounds affect brain function and behavior. His current work focuses on the neural mechanisms underlying <mark>socio-affective processes such as empathy and compassion</mark>, as well as on <mark>neurometabolic modeling</mark> approaches to better characterize psychedelic-induced changes in brain dynamics.`,
    ],
  },
  {
    id: 'speaker-gerhard-gruender',
    name: 'Gerhard Gründer',
    title: 'Prof. Dr. med.',
    affiliations: ['ZI Mannheim', 'MIND Foundation'],
    image: '/assets/speakers-gerhard-gruender.jpg',
    bio: [
      `Prof. Dr. med. Gerhard Gründer is Professor of Psychiatry and Head of the Department of Molecular Neuroimaging at the <strong>Central Institute of Mental Health (ZI), Mannheim</strong>, where he studies novel treatments for mood and psychotic disorders using <mark>functional brain imaging (PET and fMRI)</mark>.`,
      `He is the initiator and Principal Investigator of the <mark>EPIsoDE study</mark>, Germany's psilocybin depression trial run across Mannheim and the Charité Berlin. Under his direction, the ZI received approval for the <mark>European Union's first compassionate-use programme for psilocybin</mark> in treatment-resistant depression. He is also Medical Director of the <strong>OVID Clinic Berlin</strong> and Scientific Advisor to the Board of the <strong>MIND Foundation</strong>.`,
    ],
  },
  {
    id: 'speaker-martha-havenith',
    name: 'Martha Havenith',
    title: 'PhD',
    affiliations: ['Ernst Strüngmann Institute', 'Max Planck Society'],
    scholar: 'https://scholar.google.com/citations?user=EY_4zioAAAAJ',
    image: '/assets/speakers-martha-havenith.jpg',
    bio: [
      `Martha is a Max Planck research group leader at the <strong>Ernst-Strungmann Institute for Neuroscience</strong> in Frankfurt, Germany, where she uses <mark>virtual reality to study how neurons juggle coexisting cognitive processes</mark> during natural behaviour. Her previous career milestones include an M.Sc. in Neuroscience at <strong>Oxford University</strong>, a Ph.D. at the <strong>Max Planck Institute for Brain Research</strong>, and postdoctoral research fellowships at <strong>University College London</strong> and the <strong>Donders Institute for Brain, Cognition and Behaviour</strong> in Nijmegen, Netherlands.`,
      `Martha is also a <mark>certified breathwork facilitator</mark> with a decade of experience. Apart from breathwork sessions in individual and group settings, she leads facilitator trainings and workshops for healthcare professionals. In recent years, Martha has been leading pioneering research on the neuronal and clinical effects of breathwork, including a first-of-its-kind study on <mark>breathwork and trauma processing</mark>. Together with Abdel Nemri, she has also co-authored <mark>The Breathwork Handbook</mark>: an exploration of the history, neuroscience, psychology, and most importantly the principled practice of breathwork. With this work, Martha's passion is to bridge science and lived experience in exploring the power of breathing.`,
    ],
  },
  {
    id: 'speaker-friederike-holze',
    name: 'Friederike Holze',
    title: 'Dr.',
    affiliations: ['University of Basel'],
    image: '/assets/speakers-friederike-holze.jpg',
    bio: [
      `Dr. Friederike Holze is a Swiss researcher in the <mark>psychopharmacology of psychedelics</mark>. She completed her PhD in <strong>Prof. Matthias Liechti's group at the University Hospital Basel</strong> (2021), running Phase I and II trials that established a <mark>dose-effect relationship for LSD</mark> and compared the acute effects of LSD, MDMA, psilocybin, and d-amphetamine.`,
      `As an SNSF fellow at <strong>Rigshospitalet Copenhagen</strong>, she studied psychedelics with <mark>PET and fMRI</mark>, including serotonin 2A receptor occupancy, and has personally supervised more than 200 sessions. Her work earned the 2023 NEATOR and 2024 Sommerfeld-Ziskind awards. She is now a lecturer at the <strong>University of Basel</strong>.`,
    ],
  },
  {
    id: 'speaker-morten-lietz',
    name: 'Morten Lietz',
    title: 'PhD candidate',
    affiliations: ['University of Fribourg'],
    scholar: 'https://scholar.google.com/citations?user=O-lRCnMAAAAJ',
    image: '/assets/speakers-morten-lietz.jpg',
    bio: [
      `Morten Lietz is pursuing a Ph.D. in Medical Science, studying <mark>LSD's effects on neuroplasticity across the lifespan</mark> in a large clinical trial. His work combines neurophysiological, cognitive, subjective, and safety-related measures to examine <mark>psychedelic effects in healthy aging</mark>.`,
      `He previously helped establish a research program at the <strong>University of Groningen</strong> in the Netherlands under Prof. Enriquez-Geppert, exploring <mark>neuroplasticity-enhancing agents and neuromodulation</mark> to improve cognition. He also co-organized the first two Summer Schools on Psychedelic Research in Groningen with Dr. Joost Breeksema and the <strong>OPEN Foundation</strong>.`,
      `In Switzerland, he served as Educational Program Coordinator for the <strong>ALPS Foundation</strong>, organizing conferences and summer schools, and now supports the <strong>ALPS PsyCare</strong> initiative focused on <mark>harm reduction and psychological support</mark>.`,
      `His research interests include psychedelics' effects on <mark>memory, genetics and epigenetics, cognition, and safety</mark>.`,
    ],
  },
  {
    id: 'speaker-daniel-meling',
    name: 'Daniel Meling',
    title: 'PhD',
    affiliations: ['University of Zurich', 'University of Freiburg'],
    scholar: 'https://scholar.google.com/citations?user=qC2w-eMAAAAJ',
    image: '/assets/speakers-daniel-meling.jpg',
    bio: [
      `Daniel Meling has a PhD in Human Sciences, an MSc in Cognitive Science, and a BA in Educational Science and Education Management. In his previous work, he has focused on applying <mark>enactive cognitive science to meditation, non-dual awareness, and psychedelic experiences</mark>.`,
      `In his empirical research, he conducted more than a hundred <mark>phenomenological interviews around psychedelic experiences</mark>, including the study of interaction effects between <mark>DMT-harmine and meditative practices</mark> in experienced meditators during an RCT conducted at a meditation group retreat.`,
    ],
  },
  {
    id: 'speaker-maria-sansoni',
    name: 'Maria Sansoni',
    title: 'Dr.',
    affiliations: ['Catholic University, Milan'],
    image: '/assets/speakers-maria-sansoni.jpg',
    bio: [
      `Maria Sansoni holds a PhD in Psychology and is a postdoctoral researcher at the <strong>Humane Technology Lab, Catholic University of the Sacred Heart, Milan</strong>. Her work uses <mark>Virtual Reality</mark> to develop innovative interventions and assessment tools that enhance psychological wellbeing.`,
      `She explores the therapeutic potential of <mark>cyberdelics</mark> — integrating psychedelic-inspired principles with immersive digital technologies — to create transformative, embodied experiences, investigating how they can promote <mark>body image flexibility</mark> and support mental health. Through her work she aims to bridge scientific innovation and psychological care, developing human-centred technologies that foster wellbeing and personal transformation.`,
    ],
  },
  {
    id: 'speaker-daniel-villiger',
    name: 'Daniel Villiger',
    title: 'PhD',
    affiliations: ['University of Zurich'],
    scholar: 'https://scholar.google.com/citations?user=1ic60aMAAAAJ',
    image: '/assets/speakers-daniel-villiger.jpg',
    bio: [
      `Daniel Villiger, PhD, is a philosopher with an interdisciplinary background and main interests in <mark>decision theory, cognitive science, and bioethics</mark>. He holds a PhD in Philosophy from the <strong>University of Zurich</strong>, a PhD in Behavioral Economics from the <strong>University of St. Gallen</strong>, and an MSc in Psychology from the <strong>University of Zurich</strong>.`,
      `From 2024 to 2025, he conducted the project <mark>Psychedelic Ethics at the Uehiro Oxford Institute</mark> at the <strong>University of Oxford</strong>. He is currently a postdoctoral researcher at the <strong>University of Zurich</strong>. His work has been published in the American Journal of Bioethics, Synthese, Journal of Ethics, Philosophical Psychology, Journal of Medical Ethics, and other journals.`,
    ],
  },
  {
    id: 'speaker-serge-weydert',
    name: 'Serge Weydert',
    affiliations: ['Aeon'],
    image: '/assets/speakers-serge-weydert.jpg',
    bio: [
      `Serge Weydert is a neuroscientist and serial entrepreneur. He has founded and sold two health-tech start-ups — one in <mark>neurorehabilitation</mark> and another in the wearable space, <mark>training parasympathetic activity through biofeedback and breathwork</mark>. He is now Chief Product and Technology Officer at <strong>Aeon</strong>, a preventive-healthcare company, and is privately engaged in supporting psychedelic research.`,
    ],
  },
  {
    id: 'speaker-parsa-yousefi',
    name: 'Parsa Yousefi',
    title: 'PhD candidate',
    affiliations: ['University of Fribourg', 'ALPS Foundation'],
    image: '/assets/speakers-parsa-yousefi.jpg',
    bio: [
      `Parsa Yousefi is a doctoral researcher at the <strong>Molecular Psychiatry Lab, University of Fribourg</strong>, working under Prof. Gregor Hasler. His research investigates <mark>altered states of consciousness, psychedelics, bodily self-consciousness, and interoception</mark>, combining neuroimaging, EEG, virtual reality, and respiratory physiology. His current project, <mark>HYPERSELF</mark>, is a multimodal study of how hyperventilation-induced altered states reshape bodily self-experience.`,
      `Alongside his PhD, Parsa contributes to research at the <strong>ALPS Foundation</strong> and coordinates the educational programme of the ALPS Summer School.`,
    ],
  },
];

const speakerId: Record<string, string> = Object.fromEntries(
  speakers.map((s) => [s.name, s.id]),
);

// First timetable slot where each speaker appears -> anchor id, so bios can link back to the programme.
const speakerSlot: Record<string, string> = {};
schedule.forEach((day) =>
  day.sessions.forEach((s, i) => {
    const names = s.speaker ? [s.speaker] : (s.panelists ?? []);
    names.forEach((nm) => {
      const id = speakerId[nm];
      if (id && !(id in speakerSlot)) speakerSlot[id] = `slot-d${day.num}-${i}`;
    });
  }),
);

const kindLabel: Record<string, string> = {
  workshop: 'Workshop',
  panel: 'Panel',
  social: 'Social',
  closing: 'Closing',
};

// Official websites for the affiliation badges (reviewed 2026-06-02).
const affiliationUrl: Record<string, string> = {
  'University of Zurich': 'https://www.uzh.ch/en.html',
  'University of Basel': 'https://www.unibas.ch/en.html',
  'University Hospital Basel': 'https://www.unispital-basel.ch/en/',
  'University of Fribourg': 'https://www.unifr.ch/home/en/',
  'University of Freiburg': 'https://uni-freiburg.de/en/',
  'University Hospital of Psychiatry Zurich': 'https://www.pukzh.ch/',
  'ZI Mannheim': 'https://www.zi-mannheim.de/en.html',
  'MIND Foundation': 'https://mind-foundation.org/',
  'Ernst Strüngmann Institute': 'https://www.esi-frankfurt.de/',
  'Max Planck Society': 'https://www.mpg.de/en',
  'Catholic University, Milan': 'https://www.unicatt.it/en.html',
  'Reconnect Labs': 'https://reconnect-labs.com/',
  'Aeon': 'https://aeon.life/',
  'ALPS Foundation': 'https://alps.foundation/',
};
---

<section id="program" class="py-[clamp(4rem,8vw,7rem)]">
  <div class="container-x">
    <div class="mb-[clamp(2rem,4vw,3rem)] flex max-w-[820px] flex-col gap-4">
      <span class="eyebrow self-start">Program</span>
      <h2>Six days, six themes — one cohesive journey.</h2>
      <p>
        Each full day of the ALPS Summer School 2026 pairs three morning
        lectures with an afternoon workshop and an evening gathering. The full
        day-by-day programme is below. Tap a confirmed speaker to jump to their
        bio; sessions still being finalised are marked
        <em>to be announced</em>.
      </p>
    </div>

    <ol class="m-0 grid list-none grid-cols-1 gap-4 p-0 sm:grid-cols-2 lg:grid-cols-3">
      {
        days.map((d) => (
          <li class="card group relative flex min-h-[220px] cursor-pointer flex-col gap-4 overflow-hidden">
            <a
              href={`#day-${d.num}`}
              class="absolute inset-0 z-10"
              aria-label={`Jump to ${d.theme} in the schedule`}
            />
            <div
              aria-hidden="true"
              class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-200 group-hover:opacity-100"
              style="background: radial-gradient(400px 200px at 110% -20%, rgba(154,0,109,0.18), transparent 60%);"
            />
            <div
              class="grad-text text-[2.75rem] font-medium leading-none tracking-[-0.04em]"
              aria-hidden="true"
            >
              <span>{String(d.num).padStart(2, '0')}</span>
            </div>
            <div class="flex flex-wrap items-center gap-[0.6rem]">
              <span
                class="inline-flex items-center rounded-full border border-[var(--color-border-strong)] px-[0.55rem] py-[0.2rem] text-[0.68rem] uppercase tracking-[0.14em] text-[var(--color-fg-muted)]"
              >
                {d.tag}
              </span>
              <span class="text-[0.82rem] tracking-[0.02em] text-[var(--color-fg-subtle)]">
                {d.date}
              </span>
            </div>
            <h3 class="m-0 text-[1.1rem] font-medium leading-[1.3] text-white">
              {d.theme}
            </h3>
          </li>
        ))
      }
    </ol>

    {/* Full day-by-day timetable */}
    <div class="mt-[clamp(3rem,6vw,5rem)] flex flex-col gap-10">
      {
        schedule.map((day) => (
          <div id={`day-${day.num}`} class="scroll-mt-24">
            <div class="mb-3 flex flex-wrap items-baseline gap-x-4 gap-y-1 border-b border-[var(--color-border)] pb-3">
              <span class="grad-text text-[1.6rem] font-medium leading-none tracking-[-0.04em]">
                {String(day.num).padStart(2, '0')}
              </span>
              <span class="text-[0.72rem] uppercase tracking-[0.16em] text-[var(--color-fg-subtle)]">
                {day.date}
              </span>
              <h3 class="m-0 text-[1.15rem] font-medium text-white">{day.theme}</h3>
            </div>

            <div class="flex flex-col">
              {day.sessions.map((s, i) => {
                const slotId = `slot-d${day.num}-${i}`;
                const sid = s.speaker ? speakerId[s.speaker] : undefined;
                const isLink = Boolean(sid);
                const panelists = (s.panelists ?? [])
                  .map((nm) => ({ name: nm, id: speakerId[nm] }))
                  .filter((p) => p.id);
                const meta = s.kind === 'meta';
                const tba = s.kind === 'tba';
                const label = s.kind ? kindLabel[s.kind] : undefined;
                const who = tba ? 'To be announced' : (s.speaker ?? s.title);
                const topic = tba ? 'To be announced.' : s.topic;
                const base =
                  'grid grid-cols-[7.5rem_1fr] gap-x-5 gap-y-1 border-t border-[var(--color-border)] py-3 first:border-t-0 sm:grid-cols-[8rem_13rem_1fr]';
                const whoCls =
                  (meta || tba
                    ? 'text-[0.95rem] font-medium text-[var(--color-fg-subtle)]'
                    : 'text-[0.98rem] font-semibold text-white') + (tba ? ' italic' : '');
                const topicCls =
                  'col-span-2 text-[0.9rem] leading-[1.5] sm:col-span-1 ' +
                  (meta || tba ? 'text-[var(--color-fg-subtle)]' : 'text-[var(--color-fg-muted)]') +
                  (tba ? ' italic' : '');

                return isLink ? (
                  <a
                    id={slotId}
                    href={`#${sid}`}
                    class={`group/slot -mx-3 scroll-mt-24 rounded-[var(--radius-sm)] px-3 no-underline transition-colors hover:bg-[rgba(154,0,109,0.12)] ${base}`}
                  >
                    <span class="pt-[2px] font-mono text-[0.78rem] whitespace-nowrap text-[var(--color-fg-subtle)]">
                      {s.time}
                    </span>
                    <span class={whoCls}>
                      {label && (
                        <span class="mb-[2px] block text-[0.62rem] uppercase tracking-[0.14em] text-[var(--color-accent)]">
                          {label}
                        </span>
                      )}
                      {who}
                      <span aria-hidden="true" class="ml-1 text-[var(--color-accent)] opacity-0 transition-opacity group-hover/slot:opacity-100">›</span>
                    </span>
                    {topic ? <span class={topicCls}>{topic}</span> : <span class="hidden sm:block" />}
                  </a>
                ) : (
                  <div id={slotId} class={`scroll-mt-24 ${base}`}>
                    <span class="pt-[2px] font-mono text-[0.78rem] whitespace-nowrap text-[var(--color-fg-subtle)]">
                      {s.time}
                    </span>
                    <span class={whoCls}>
                      {label && (
                        <span class="mb-[2px] block text-[0.62rem] uppercase tracking-[0.14em] text-[var(--color-accent)]">
                          {label}
                        </span>
                      )}
                      {panelists.length ? (
                        panelists.map((p, i) => (
                          <Fragment>
                            {i > 0 ? ' & ' : ''}
                            <a
                              href={`#${p.id}`}
                              class="text-white no-underline transition-colors hover:text-[var(--color-accent)] hover:underline"
                            >
                              {p.name}
                            </a>
                          </Fragment>
                        ))
                      ) : (
                        who
                      )}
                    </span>
                    {topic ? <span class={topicCls}>{topic}</span> : <span class="hidden sm:block" />}
                  </div>
                );
              })}
            </div>
          </div>
        ))
      }
    </div>

    <div
      class="mt-8 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-gradient-to-r from-[rgba(154,0,109,0.1)] to-[rgba(255,255,255,0.02)] px-6 py-5 text-[0.95rem] text-[var(--color-fg-muted)]"
    >
      The programme is provisional and subject to change. Times, sessions and
      speakers are updated as the summer school is finalised.
    </div>

    <div id="speakers" class="mt-[clamp(3.5rem,7vw,6rem)]">
      <div
        class="mb-6 flex flex-col gap-3 border-b border-[var(--color-border)] pb-4 sm:flex-row sm:items-end sm:justify-between"
      >
        <div class="flex max-w-[760px] flex-col gap-3">
          <span class="eyebrow self-start">Speakers</span>
          <h3 class="m-0 text-[clamp(1.6rem,3vw,2.2rem)]">
            Confirmed speakers and facilitators
          </h3>
        </div>
      </div>

      <div class="flex flex-col gap-5">
        {
          speakers.map((speaker) => (
            <article id={speaker.id} class="card w-full scroll-mt-24 overflow-hidden !p-0 target:border-[var(--color-accent)]">
              <div class="grid gap-0 md:grid-cols-[minmax(220px,28%)_1fr]">
                <img
                  src={speaker.image}
                  alt={speaker.name}
                  class="aspect-[4/5] h-full w-full object-cover"
                  loading="lazy"
                />
                <div class="flex flex-col gap-4 p-5 sm:p-6">
                  <div class="flex flex-col gap-2.5 md:flex-row md:items-center md:justify-between md:gap-4">
                    <div class="flex flex-wrap items-baseline gap-x-2.5 gap-y-1">
                      <h4 class="m-0 text-[1.25rem] font-medium text-white">
                        {speaker.name}
                      </h4>
                      {speaker.title && (
                        <span class="text-[0.95rem] text-[var(--color-fg-subtle)]">
                          {speaker.title}
                        </span>
                      )}
                      {speaker.scholar && (
                        <a
                          href={speaker.scholar}
                          target="_blank"
                          rel="noopener noreferrer"
                          aria-label={`${speaker.name} on Google Scholar`}
                          title="Google Scholar"
                          class="inline-flex translate-y-[2px] items-center text-[var(--color-fg-subtle)] transition-colors hover:text-[var(--color-accent)]"
                        >
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="h-[1rem] w-[1rem]"
                            aria-hidden="true"
                          >
                            <path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z" />
                          </svg>
                        </a>
                      )}
                    </div>
                    {speaker.affiliations && speaker.affiliations.length > 0 && (
                      <div class="flex flex-wrap gap-2 md:flex-shrink-0 md:justify-end">
                        {speaker.affiliations.map((aff) => {
                          const affCls =
                            'inline-flex items-center rounded-full border border-[var(--color-border-strong)] px-[0.55rem] py-[0.2rem] text-[0.68rem] uppercase tracking-[0.14em] text-[var(--color-fg-muted)]';
                          const href = affiliationUrl[aff];
                          return href ? (
                            <a
                              href={href}
                              target="_blank"
                              rel="noopener noreferrer"
                              class={`${affCls} no-underline transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]`}
                            >
                              {aff}
                            </a>
                          ) : (
                            <span class={affCls}>{aff}</span>
                          );
                        })}
                      </div>
                    )}
                  </div>
                  {speakerSlot[speaker.id] && (
                    <a
                      href={`#${speakerSlot[speaker.id]}`}
                      class="inline-flex w-fit items-center gap-1 text-[0.8rem] text-[var(--color-accent)] no-underline transition-opacity hover:underline"
                    >
                      <span aria-hidden="true">↑</span> View in the programme
                    </a>
                  )}
                  <div class="flex flex-col gap-3">
                    {speaker.bio.map((paragraph) => (
                      <p
                        class="speaker-bio m-0 text-[0.92rem] leading-[1.65] text-[var(--color-fg-muted)]"
                        set:html={paragraph}
                      />
                    ))}
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
