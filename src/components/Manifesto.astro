---
// Source of truth: ASS Manifesto Slack canvas (F0AHWTLV8V7).
const chapters = [
  {
    id: 'grounded-purpose',
    title: 'Grounded purpose',
    callout:
      'The field of psychedelic sciences tends to attract brilliance and distortion. Our responsibility is to remain grounded.',
    value:
      'We operate at the intersection of <strong>curiosity and scientific rigor</strong>. Psychedelics can inspire insight, creativity, and connection — and they can also invite overconfidence, projection, and unexamined certainty. We do not romanticize the field. We take <strong>responsibility</strong> for shaping it.',
    actions: [
      'We anchor every decision in <strong>evidence</strong>, <strong>clear reasoning</strong>, and <strong>intellectual humility</strong>.',
      'We treat ambition as something that must be <strong>disciplined by integrity</strong>.',
    ],
  },
  {
    id: 'psychological-safety',
    title: 'Psychological safety with accountability',
    callout: 'You must be able to speak without punishment.',
    value:
      'Psychological safety means <strong>disagreement is safe and silence is not enforced</strong>. It does not mean avoiding difficulty.',
    actions: [
      'We treat disagreement as data, not threat.',
      'We separate critique of strategy from critique of character.',
      'We respond to messages and concerns promptly.',
      'We ask for help early when overloaded.',
      'We reject patterns that erode trust: ignoring communication, passive avoidance, territorial behavior, and silent resentment.',
      'Silence in the face of harm is not neutrality — it is failure.',
    ],
  },
  {
    id: 'participant-experience',
    title: 'Designing the participant experience',
    callout: 'Excellent events respect both human needs and intellectual depth.',
    value:
      'Participants deserve <strong>coherence, clarity, and care</strong>. Intellectual depth requires stable conditions. They deserve to be held with <strong>kindness</strong> and <strong>compassion</strong>.',
    actions: [
      'We provide <strong>clear schedules</strong>, <strong>visible contact persons</strong>, and <strong>real-time feedback loops</strong>.',
      'We ensure foundational conditions: sufficient food, meaningful breaks, functional space, and psychological ease.',
      'We cultivate an attitude of <strong>kindness</strong> and <strong>respect</strong> when talking with participants.',
      'We curate <strong>evidence-based content</strong>, practical workshops, and structured interaction.',
      'We maintain clear boundaries and intervene immediately when required.',
      'Participants should leave feeling <strong>informed</strong>, <strong>respected</strong>, and <strong>connected</strong>.',
    ],
  },
  {
    id: 'fun-and-kindness',
    title: 'Fun and kindness as core values',
    callout: 'Excellence without joy is unsustainable. Rigor without warmth is brittle.',
    value:
      '<strong>Fun and kindness are not luxuries — they are infrastructure.</strong> A psychedelic science is deemed fulfilling if the output of energy and love outweighs the amount put in. We build environments where people want to be.',
    actions: [
      'We design space for spontaneity within structure and celebrate small wins.',
      'We create moments of levity that reduce tension without undermining focus: shared meals, playful transitions between sessions, activities that nurture connection.',
      'We resist the tendency to treat seriousness as suffering. When planning sessions, we ask: <em>Will this be intellectually rewarding AND human?</em>',
      'Fun is the practice of making collaboration sustainable. Kindness is the refusal to sacrifice people for productivity.',
    ],
  },
];

// Collective commitment keeps its own distinct closing-block styling (not a two-column card),
// but follows the same value-summary + hidden-specifics pattern as the chapters above.
const commitmentValue =
  'We commit to <strong>clarity</strong>, <strong>accountability</strong>, <strong>rigor</strong>, and <strong>care</strong> — grounding ambition in humility and building this work to last.';

const commitments = [
  'We commit to <strong>clarity</strong>, <strong>accountability</strong>, <strong>scientific rigor</strong>, and <strong>care</strong>.',
  'We commit to psychological safety paired with responsibility.',
  'We commit to disciplined execution in service of participants and collaborators.',
  'We commit to grounding ambition in humility.',
  'We commit to making this work sustainable — through kindness, care, and the belief that rigour and humanity are not opposites.',
];
---

<section id="manifesto" class="py-[clamp(4rem,8vw,7rem)]">
  <div class="container-x">
    <div class="mb-[clamp(2.5rem,5vw,4rem)] flex max-w-[820px] flex-col gap-4">
      <span class="eyebrow self-start">Manifesto</span>
      <h2>The standard we hold <span class="grad-text">ourselves</span> to.</h2>
      <p>
        Our manifesto describes how we work and what you can expect from us as
        a participant. These are the chapters that shape your experience at the
        summer school.
      </p>
    </div>

    {/* Wraps the toggle + chapters/commitment list so the toggle can stick to
        the viewport for exactly the height of this list, then release once it
        ends (position: sticky is bound to this wrapper as its containing
        block). */}
    <div class="relative">
      <div
        class="sticky z-20 mb-4 flex justify-end"
        style="top: calc(var(--nav-h) + 0.75rem)"
      >
        <label class="inline-flex w-fit shrink-0 cursor-pointer items-center gap-3 rounded-full border border-[var(--color-border-strong)] bg-[rgba(5,0,7,0.75)] px-4 py-[0.6rem] backdrop-blur-xl backdrop-saturate-[1.4] transition-colors supports-[backdrop-filter]:bg-[rgba(5,0,7,0.55)] hover:border-[var(--color-accent)]">
          {/* The knob must be a direct sibling of the checkbox (not nested
              inside the track span) — Tailwind's peer-checked variant compiles
              to a `~` general-sibling selector, which can't reach into a
              sibling's descendants. This mirrors the working toggle in
              Program.astro. */}
          <span class="relative inline-flex h-[1.4rem] w-[2.6rem] flex-shrink-0 items-center">
            <input type="checkbox" id="manifesto-toggle" class="peer absolute inset-0 z-10 h-full w-full cursor-pointer opacity-0" />
            <span
              aria-hidden="true"
              class="pointer-events-none absolute inset-0 rounded-full bg-[var(--color-border-strong)] transition-colors duration-200 peer-checked:bg-[var(--color-accent)]"
            />
            <span
              aria-hidden="true"
              class="pointer-events-none absolute left-[3px] h-[1.05rem] w-[1.05rem] rounded-full bg-white transition-transform duration-200 peer-checked:translate-x-[1.2rem]"
            />
          </span>
          <span class="text-[0.85rem] font-medium text-white">Show specifics</span>
        </label>
      </div>

      <div class="flex flex-col gap-4">
      {
        chapters.map((c) => (
          <article id={c.id} class="card grid gap-6 md:grid-cols-[minmax(0,5fr)_minmax(0,7fr)] md:gap-10">
            <div class="flex flex-col gap-4">
              <h3 class="m-0">{c.title}</h3>
              <p
                class="m-0 border-l-2 border-[var(--color-primary)] pl-4 text-[1.02rem] italic text-white/85"
                set:html={c.callout}
              />
            </div>
            <p class="m-0 self-center text-[0.95rem] text-[var(--color-fg-muted)]" set:html={c.value} />
            <div data-manifesto-detail class="md:col-span-2 md:border-t md:border-[var(--color-border)] md:pt-6">
              <ul class="m-0 flex list-none flex-col gap-3 p-0">
                {c.actions.map((a) => (
                  <li class="flex items-start gap-[0.9rem] text-[0.95rem] text-[var(--color-fg-muted)]">
                    <span
                      aria-hidden="true"
                      class="grad-primary mt-[0.55rem] h-[7px] w-[7px] flex-shrink-0 rounded-full"
                    />
                    <span set:html={a} />
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }

      <div id="collective-commitment" class="gradient-border">
        <div
          class="relative z-[1] flex flex-col gap-5 rounded-[inherit] bg-[var(--color-bg-elev)]/95 p-[clamp(1.5rem,3.5vw,2.75rem)]"
        >
          <h3 class="m-0">Collective commitment</h3>
          <p class="m-0 max-w-[760px] text-[1.02rem] italic text-white/85">
            We build deliberately. We act responsibly. We protect the integrity
            of our work and our field. We do this with joy and warmth.
          </p>
          <p class="m-0 max-w-[760px] text-[0.95rem] text-[var(--color-fg-muted)]" set:html={commitmentValue} />
          <div data-manifesto-detail class="border-t border-[var(--color-border)] pt-5">
            <ul class="m-0 flex list-none flex-col gap-3 p-0">
              {
                commitments.map((c) => (
                  <li class="flex items-start gap-[0.9rem] text-[0.95rem] text-[var(--color-fg-muted)]">
                    <span
                      aria-hidden="true"
                      class="grad-primary mt-[0.55rem] h-[7px] w-[7px] flex-shrink-0 rounded-full"
                    />
                    <span set:html={c} />
                  </li>
                ))
              }
            </ul>
          </div>
          <p class="m-0 font-medium text-white">
            This is the standard we hold each other to.
            <br />
            This is ALPS Summer School.
          </p>
        </div>
      </div>
      </div>
    </div>
  </div>
</section>

<style>
  #manifesto :global(strong) {
    font-weight: 500;
    color: rgba(255, 255, 255, 0.95);
  }

  #manifesto [data-manifesto-detail] {
    display: none;
  }

  #manifesto:has(#manifesto-toggle:checked) [data-manifesto-detail] {
    display: block;
  }
</style>
