---

<section id="manifesto" class="py-[clamp(4rem,8vw,7rem)]">
  <div class="container-x">
    <div class="mb-[clamp(2.5rem,5vw,4rem)] flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
      <div class="flex max-w-[820px] flex-col gap-4">
        <span class="eyebrow self-start">Manifesto</span>
        <h2>The standard we hold <span class="grad-text">ourselves</span> to.</h2>
        <p>
          Our manifesto describes how we work and what you can expect from us as
          a participant. These are the chapters that shape your experience at the
          summer school.
        </p>
      </div>
      <label class="inline-flex w-fit shrink-0 cursor-pointer items-center gap-3 self-start rounded-full border border-[var(--color-border-strong)] bg-white/[0.04] px-4 py-[0.6rem] transition-colors hover:border-[var(--color-accent)] sm:self-end">
        <input type="checkbox" id="manifesto-toggle" class="peer sr-only" />
        <span
          aria-hidden="true"
          class="relative inline-flex h-[1.4rem] w-[2.6rem] flex-shrink-0 items-center rounded-full bg-[var(--color-border-strong)] transition-colors duration-200 peer-checked:bg-[var(--color-accent)]"
        >
          <span class="absolute left-[3px] h-[1.05rem] w-[1.05rem] rounded-full bg-white transition-transform duration-200 peer-checked:translate-x-[1.2rem]" />
        </span>
        <span class="text-[0.85rem] font-medium text-white">Show specifics</span>
      </label>
    </div>

    <div class="flex flex-col gap-4">
      {
        chapters.map((c) => (
          <article id={c.id} class="card grid gap-6 md:grid-cols-[minmax(0,5fr)_minmax(0,7fr)] md:gap-10">
            <div class="flex flex-col gap-4">
              <h3 class="m-0">{c.title}</h3>
              <p
                class="m-0 border-l-2 border-[var(--color-primary)] pl-4 text-[1.02rem] italic text-white/85"
                set:html={c.callout}
              />
              <p class="m-0 text-[0.95rem]" set:html={c.value} />
            </div>
            <div class="flex flex-col gap-4 self-center">
              {c.prose.map((p) => (
                <p class="m-0 text-[0.95rem] text-[var(--color-fg-muted)]" set:html={p} />
              ))}
              <ul data-manifesto-detail class="m-0 flex list-none flex-col gap-3 p-0">
                {c.actions.map((a) => (
                  <li class="flex items-start gap-[0.9rem] text-[0.95rem] text-[var(--color-fg-muted)]">
                    <span
                      aria-hidden="true"
                      class="grad-primary mt-[0.55rem] h-[7px] w-[7px] flex-shrink-0 rounded-full"
                    />
                    <span set:html={a} />
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }

      <div id="collective-commitment" class="gradient-border">
        <div
          class="relative z-[1] flex flex-col gap-5 rounded-[inherit] bg-[var(--color-bg-elev)]/95 p-[clamp(1.5rem,3.5vw,2.75rem)]"
        >
          <h3 class="m-0">Collective commitment</h3>
          <p class="m-0 max-w-[760px] text-[1.02rem] italic text-white/85">
            We build deliberately. We act responsibly. We protect the integrity
            of our work and our field. We do this with joy and warmth.
          </p>
          <div class="flex max-w-[760px] flex-col gap-4">
            {commitmentsProse.map((p) => (
              <p class="m-0 text-[0.95rem] text-[var(--color-fg-muted)]" set:html={p} />
            ))}
          </div>
          <ul data-manifesto-detail class="m-0 flex list-none flex-col gap-3 p-0">
            {
              commitments.map((c) => (
                <li class="flex items-start gap-[0.9rem] text-[0.95rem] text-[var(--color-fg-muted)]">
                  <span
                    aria-hidden="true"
                    class="grad-primary mt-[0.55rem] h-[7px] w-[7px] flex-shrink-0 rounded-full"
                  />
                  <span set:html={c} />
                </li>
              ))
            }
          </ul>
          <p class="m-0 font-medium text-white">
            This is the standard we hold each other to.
            <br />
            This is ALPS Summer School.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #manifesto :global(strong) {
    font-weight: 500;
    color: rgba(255, 255, 255, 0.95);
  }

  #manifesto [data-manifesto-detail] {
    display: none;
  }

  #manifesto:has(#manifesto-toggle:checked) [data-manifesto-detail] {
    display: flex;
  }
</style>
