const commitmentsProse = [
  'We commit to <strong>clarity</strong>, <strong>accountability</strong>, <strong>scientific rigor</strong>, and <strong>care</strong> — to psychological safety paired with responsibility, and to disciplined execution in service of participants and collaborators.',
  'We commit to grounding ambition in humility, and to making this work <strong>sustainable</strong> — through kindness, care, and the belief that rigour and humanity are not opposites.',
];

const commitments = [
  'We commit to <strong>clarity</strong>, <strong>accountability</strong>, <strong>scientific rigor</strong>, and <strong>care</strong>.',
  'We commit to psychological safety paired with responsibility.',
