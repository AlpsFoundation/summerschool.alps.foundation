---
const links = [
  { id: 'about', label: 'About' },
  { id: 'program', label: 'Program' },
  { id: 'speakers', label: 'Speakers' },
  { id: 'venue', label: 'Venue' },
  { id: 'people', label: 'People' },
  { id: 'manifesto', label: 'Manifesto' },
];
---

<header
  class="sticky top-0 z-50 isolate border-b border-[var(--color-border)] bg-[rgba(5,0,7,0.72)] backdrop-blur-xl backdrop-saturate-[1.4] supports-[backdrop-filter]:bg-[rgba(5,0,7,0.38)]"
>
  <div class="grad-primary px-4 py-[0.5rem] text-center text-white">
    <p class="m-0 text-[0.88rem] font-medium leading-snug">
      A few spots have opened up — the waiting list for 2026 is still open.
      <a
        href="https://docs.google.com/forms/d/e/1FAIpQLScbruwrTJoezVXMo9Wf-L62wcfEnWKX8PllpCaui1l3TiWEMw/viewform"
        target="_blank"
        rel="noopener noreferrer"
        class="whitespace-nowrap underline underline-offset-[3px] transition-opacity hover:opacity-90"
      >Join the waiting list →</a>
    </p>
    <p class="m-0 mt-[2px] text-[0.82rem] font-normal leading-snug text-white/90">
      Are the fees a stretch? Whether you’re interested or already taking part,
      <a
        href="mailto:summerschool@alps.foundation?subject=ALPS%20Summer%20School%20%E2%80%94%20fees"
        class="whitespace-nowrap underline underline-offset-[3px] transition-opacity hover:opacity-90"
      >get in touch</a> — we’re open to talking.
    </p>
  </div>
  <div class="container-x flex items-center justify-between gap-5 py-[0.9rem]">
    <a
      href="/"
      class="inline-flex items-center gap-[0.65rem] text-white hover:text-white hover:opacity-90"
      aria-label="ALPS Summer School — home"
    >
      <img
        src="/assets/logo.png"
        alt=""
        width="30"
        height="30"
        class="h-[30px] w-[30px] rounded-[var(--radius-sm)] border border-[var(--color-border)] bg-white/[0.04] p-[3px]"
      />
      <span class="flex flex-col leading-[1.1]">
        <span class="text-[0.95rem] font-semibold tracking-[0.08em]">ALPS</span>
        <span
          class="hidden text-[0.72rem] uppercase tracking-[0.08em] text-[var(--color-fg-subtle)] min-[380px]:block"
        >
          Summer School 2026
        </span>
      </span>
    </a>

    <nav
      class="hidden items-center gap-[1.6rem] text-[0.92rem] text-[var(--color-fg-muted)] md:inline-flex"
      aria-label="Primary"
    >
      {
        links.map((l) => (
          <a
            href={`/#${l.id}`}
            data-scrollspy-target={l.id}
            class="nav-link group relative text-[var(--color-fg-muted)] transition-colors duration-200 hover:text-white aria-[current=location]:text-white"
          >
            {l.label}
            <span
              aria-hidden="true"
              class="grad-primary absolute inset-x-0 -bottom-[6px] h-[2px] origin-left scale-x-0 rounded-[2px] transition-transform duration-200 group-hover:scale-x-100 group-aria-[current=location]:scale-x-100"
            />
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2 md:gap-3">
      <a
        href="https://docs.google.com/forms/d/e/1FAIpQLScbruwrTJoezVXMo9Wf-L62wcfEnWKX8PllpCaui1l3TiWEMw/viewform"
        target="_blank"
        rel="noopener noreferrer"
        class="btn text-[0.88rem] !px-4 !py-[0.55rem]"
      >
        Join waiting list
      </a>
      <button
        id="nav-toggle"
        type="button"
        class="-mr-1 inline-flex items-center justify-center rounded-[var(--radius-sm)] p-2 text-[var(--color-fg-muted)] transition-colors hover:text-white md:hidden"
        aria-label="Toggle navigation menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <svg data-icon="open" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <svg data-icon="close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="6" y1="6" x2="18" y2="18" /><line x1="6" y1="18" x2="18" y2="6" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    data-open="false"
    inert
    class="grid overflow-hidden bg-[rgba(5,0,7,0.96)] md:hidden"
  >
    <div class="min-h-0 overflow-hidden">
      <nav class="container-x flex flex-col border-t border-[var(--color-border)] py-1" aria-label="Mobile">
        {
          links.map((l) => (
            <a
              href={`/#${l.id}`}
              data-scrollspy-target={l.id}
              data-mobile-link
              class="border-b border-[var(--color-border)] py-3 text-[1rem] text-[var(--color-fg-muted)] transition-colors last:border-b-0 hover:text-white aria-[current=location]:text-white"
            >
              {l.label}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</header>

<div
  id="mobile-backdrop"
  data-open="false"
  aria-hidden="true"
  class="fixed inset-0 z-40 bg-black/50 backdrop-blur-[2px] md:hidden"
>
</div>

<style>
  #mobile-menu {
    grid-template-rows: 0fr;
    opacity: 0;
    transition:
      grid-template-rows 300ms ease,
      opacity 250ms ease;
  }
  #mobile-menu[data-open='true'] {
    grid-template-rows: 1fr;
    opacity: 1;
  }
  #mobile-backdrop {
    opacity: 0;
    pointer-events: none;
    transition: opacity 300ms ease;
  }
  #mobile-backdrop[data-open='true'] {
    opacity: 1;
    pointer-events: auto;
  }
  @media (prefers-reduced-motion: reduce) {
    #mobile-menu,
    #mobile-backdrop {
      transition: none;
    }
  }
</style>

<script>
  function syncNavHeightVar() {
    const header = document.querySelector('header');
    if (!header) return 0;
    const h = header.getBoundingClientRect().height;
    document.documentElement.style.setProperty('--nav-h', `${h}px`);
    return h;
  }

  function updateScrollSpy() {
    const links = Array.from(document.querySelectorAll('[data-scrollspy-target]'));
    const ids = links
      .map((el) => /** @type {HTMLElement} */ (el).dataset.scrollspyTarget)
      .filter(Boolean);
    const navH = syncNavHeightVar() || 72;
    const activationY = window.scrollY + navH + 14;

    /** @type {string | null} */
    let activeId = null;
    for (const id of ids) {
      const section = document.getElementById(id);
      if (!section) continue;
      const top = section.getBoundingClientRect().top + window.scrollY;
      if (top <= activationY) activeId = id;
    }

    for (const link of links) {
      const id = /** @type {HTMLElement} */ (link).dataset.scrollspyTarget;
      const on = id === activeId;
      if (on) link.setAttribute('aria-current', 'location');
      else link.removeAttribute('aria-current');
    }
  }

  let ticking = false;
  function onScrollOrResize() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      updateScrollSpy();
      ticking = false;
    });
  }

  updateScrollSpy();
  window.addEventListener('scroll', onScrollOrResize, { passive: true });
  window.addEventListener('resize', onScrollOrResize);
  window.addEventListener('hashchange', updateScrollSpy);

  // Mobile dropdown menu toggle (animated, with backdrop + tap-outside-to-close)
  const navToggle = document.getElementById('nav-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileBackdrop = document.getElementById('mobile-backdrop');
  if (navToggle && mobileMenu) {
    const openIcon = navToggle.querySelector('[data-icon="open"]');
    const closeIcon = navToggle.querySelector('[data-icon="close"]');
    const isOpen = () => navToggle.getAttribute('aria-expanded') === 'true';
    const setMenu = (open) => {
      navToggle.setAttribute('aria-expanded', String(open));
      mobileMenu.dataset.open = String(open);
      if (open) mobileMenu.removeAttribute('inert');
      else mobileMenu.setAttribute('inert', '');
      if (mobileBackdrop) mobileBackdrop.dataset.open = String(open);
      if (openIcon) openIcon.classList.toggle('hidden', open);
      if (closeIcon) closeIcon.classList.toggle('hidden', !open);
    };
    navToggle.addEventListener('click', () => setMenu(!isOpen()));
    if (mobileBackdrop)
      mobileBackdrop.addEventListener('click', () => setMenu(false));
    mobileMenu
      .querySelectorAll('[data-mobile-link]')
      .forEach((a) => a.addEventListener('click', () => setMenu(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setMenu(false);
    });
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768) setMenu(false);
    });
  }
</script>
